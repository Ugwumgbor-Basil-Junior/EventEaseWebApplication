@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container mt-5">

    <!-- Alerts -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- Header -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold">Event Schedule</h2>
            <small class="text-muted">Manage all upcoming events</small>
        </div>

        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary">
                Create Event
            </a>
        </div>
    </div>

    <!-- EVENT LIST (not table) -->
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-3">

                <div class="card border-0 shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between">

                            <div>

                                <h5 class="mb-1">@item.EventName</h5>

                                <div class="text-muted small">
                                    @item.Venue.Location
                                </div>

                                <div class="small mt-2">
                                    <div>Date: @item.EventDate.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted">
                                        @item.Description
                                    </div>
                                </div>

                            </div>

                            <div class="text-end">

                                <a asp-action="Details" asp-route-id="@item.EventID"
                                       class="btn btn-sm btn-outline-primary mb-1">
                                    View
                                </a>

                                <br />

                                <a asp-action="Edit" asp-route-id="@item.EventID"
                                       class="btn btn-sm btn-outline-warning mb-1">
                                    Edit
                                </a>

                                <br />

                                <a asp-action="Delete" asp-route-id="@item.EventID"
                                       class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>