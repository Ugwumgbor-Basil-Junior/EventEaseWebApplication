@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">@ViewData["Title"]</h1>
            
            <p class="text-muted">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

            <div class="mb-4">
                <h3>Information We Collect</h3>
                <p>We collect your name, email, phone number, and event booking details when you use our platform.</p>
            </div>

            <div class="mb-4">
                <h3>How We Use Your Information</h3>
                <p>We use your information to process bookings, send confirmations, and improve our services. We do not sell your personal data.</p>
            </div>

            <div class="mb-4">
                <h3>Data Security</h3>
                <p>We take reasonable measures to protect your information from unauthorized access or disclosure.</p>
            </div>

            <div class="mb-4">
                <h3>Contact Us</h3>
                <p>If you have questions about this privacy policy, please contact us at: <strong>privacy@eventease.com</strong></p>
            </div>

            <hr />

            <p class="text-muted small">By using EventEase, you agree to this privacy policy.</p>
        </div>
    </div>
</div>