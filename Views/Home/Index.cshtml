@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4 mb-4">Welcome to EventEase</h1>
    <p class="lead mb-5">Your Complete Event Management Solution</p>
    
    <div class="row mt-5">
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h3 class="card-title text-primary">Events</h3>
                    <p class="card-text">Create and manage all your events in one place.</p>
                    <a asp-controller="Event" asp-action="Index" class="btn btn-primary">View Events</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h3 class="card-title text-primary">Venues</h3>
                    <p class="card-text">Browse and find the perfect venue for your event.</p>
                    <a asp-controller="Venue" asp-action="Index" class="btn btn-primary">View Venues</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h3 class="card-title text-primary">Bookings</h3>
                    <p class="card-text">Manage your event bookings and reservations.</p>
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-primary">View Bookings</a>
                </div>
            </div>
        </div>
    </div>   
     
    <div class="mt-5 p-4 bg-light rounded">
        <h3>Ready to get started?</h3>
        <p>Create a new event or make a booking today!</p>
        <a asp-controller="Event" asp-action="Create" class="btn btn-success">Create Event</a>
        <a asp-controller="Booking" asp-action="Create" class="btn btn-info text-white">Make Booking</a>
    </div>
</div>