@model IEnumerable<EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="container mt-5">

    <!-- Header -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold">Venue Management</h2>
            <small class="text-muted">Manage all available venues in the system</small>
        </div>

        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary">
                Add Venue
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- LIST STYLE (NOT CARDS) -->
    <div class="list-group shadow-sm">

        @foreach (var item in Model)
        {
            <div class="list-group-item p-3">

                <div class="row align-items-center">

                    <!-- Image -->
                    <div class="col-md-2">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                                                                                                              ? "/images/default-venue.jpg"
                                                                                                                                              : item.ImageUrl)"
                             style="width:100%; height:80px; object-fit:cover; border-radius:8px;" />
                    </div>

                    <!-- Info -->
                    <div class="col-md-6">

                        <h5 class="mb-1">@item.VenueName</h5>

                        <div class="text-muted small">
                            @item.Location
                        </div>

                        <div class="small mt-1">
                            Capacity: <strong>@item.Capacity</strong>
                        </div>

                    </div>

                    <!-- Actions -->
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">

                        <a asp-action="Details" asp-route-id="@item.VenueID"
                               class="btn btn-sm btn-outline-primary">
                            View
                        </a>

                        <a asp-action="Edit" asp-route-id="@item.VenueID"
                               class="btn btn-sm btn-outline-warning">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.VenueID"
                               class="btn btn-sm btn-outline-danger">
                            Delete
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>
