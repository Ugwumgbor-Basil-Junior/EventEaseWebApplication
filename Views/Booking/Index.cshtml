@model IEnumerable<EventEase.Models.BookingViewModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<form asp-action="Index" method="get" class="mb-3">
    <input type="text" name="searchString" value="@ViewBag.CurrentFilter" placeholder="Search by Booking ID or Event Name..." />
    <input type="submit" value="Search" />
    <a asp-action="Index">Clear</a>
</form>

<p> 
    <a asp-action="Create">Create New</a>
</p>

<!-- Consolidated View To Display Bookings More Efficiently -->
<table class="table">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Event Name</th>
            <th>Event Date</th>
            <th>Venue Name</th>
            <th>Venue Location</th>
            <th>Booking Date</th>
            <th>Capacity</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.BookingID</td>
                <td>@booking.EventName</td>
                <td>@booking.EventDate.ToString("yyyy-MM-dd")</td>
                <td>@booking.VenueName</td>
                <td>@booking.VenueLocation</td>
                <td>@booking.BookingDate.ToString("yyyy-MM-dd")</td>
                <td>@booking.Capacity</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@booking.BookingID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@booking.BookingID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@booking.BookingID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<!-- End of Update -->