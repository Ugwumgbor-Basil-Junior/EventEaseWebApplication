@model IEnumerable<EventEase.Models.BookingViewModel>

@{
    ViewData["Title"] = "Bookings";
}

<div class="container mt-5">

    <!-- Header -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold">Booking Overview</h2>
            <small class="text-muted">View and manage all event bookings</small>
        </div>

        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary">
                New Booking
            </a>
        </div>
    </div>

    <!-- Search -->
    <form asp-action="Index" method="get" class="mb-4">
        <input type="text"
               name="searchString"
               class="form-control"
               placeholder="Search by Booking ID or Event Name..."
               value="@Context.Request.Query["searchString"]" />
    </form>

    <!-- Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div class="alert alert-danger">
                @error.ErrorMessage
            </div>
        }
    }

    <!-- Card List (NOT TABLE) -->
    <div class="row">

        @foreach (var booking in Model)
        {
            <div class="col-md-6 mb-3">

                <div class="card border-0 shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between">

                            <div>
                                <h5 class="mb-1">Booking #@booking.BookingID</h5>

                                <div class="text-muted small">
                                    @booking.EventName • @booking.VenueName
                                </div>

                                <div class="small mt-2">
                                    <div>Date: @booking.EventDate.ToString("dd MMM yyyy")</div>
                                    <div>Location: @booking.Location</div>
                                    <div>Capacity: @booking.Capacity</div>
                                    <div>Booked: @booking.BookingDate.ToString("dd MMM yyyy")</div>
                                </div>

                            </div>

                            <div class="text-end">

                                <a asp-action="Details" asp-route-id="@booking.BookingID"
                                       class="btn btn-sm btn-outline-primary mb-1">
                                    View
                                </a>

                                <br />

                                <a asp-action="Edit" asp-route-id="@booking.BookingID"
                                       class="btn btn-sm btn-outline-warning mb-1">
                                    Edit
                                </a>

                                <br />

                                <a asp-action="Delete" asp-route-id="@booking.BookingID"
                                       class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>